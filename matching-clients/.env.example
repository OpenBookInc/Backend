# ====================
# REQUIRED VARIABLES
# ====================

# AWS
PG_HOST=your-database-host
PG_PORT=5432
PG_DATABASE=your-database-name
PG_USER=your-database-user
PG_PASSWORD=your-database-password
PG_KEY_PATH=/path/to/ssl/certificate.pem

# Matching Server Host
SERVER_HOST=localhost

# Matching Server Port
SERVER_PORT=50051

# ====================
# OPTIONAL VARIABLES
# ====================

# Web Interface Port (default: 8080)
WEB_PORT=8080

# Gateway gRPC Server Port (default: 50052)
GATEWAY_PORT=50052

# User IDs and leg IDs for new orders sent to gateway
GATEWAY_USER_IDS=abcdefgh-0000-1111-2222-ijklmnopqrst,12345678-9999-aaaa-bbbb-ccccddddeeee
GATEWAY_LEG_IDS=01234567-89ab-cdef-0123-456789abcdef,fedcba98-7654-3210-fedc-ba9876543210
