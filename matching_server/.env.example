# ====================
# REQUIRED VARIABLES
# ====================

# Matching Engine Port (REQUIRED)
# The gRPC port on which the matching engine server will listen
# Default was 50051
ENGINE_PORT=50051

# ====================
# OPTIONAL VARIABLES
# ====================

# Heartbeat Interval in Milliseconds (default: 0, disabled)
# If set to a value > 0, the server will expect heartbeats from clients
# at the specified interval. This can be used for connection keepalive
# and client health monitoring.
# Example: 5000 = expect a heartbeat every 5 seconds
# Set to 0 to disable heartbeat monitoring.
HEARTBEAT_INTERVAL_MS=0
