# ====================
# REQUIRED VARIABLES
# ====================

# Matching Server Host (REQUIRED)
# Can be a URL, an IP address, or localhost
# Examples: localhost, 192.168.1.100, matching-server.example.com
SERVER_HOST=localhost

# Matching Server Port (REQUIRED)
# The gRPC port of the matching server
SERVER_PORT=50051

# ====================
# OPTIONAL VARIABLES
# ====================

# Web Interface Port (default: 8080)
# The port on which the web UI will be served
# Access the UI at http://localhost:<WEB_PORT>
WEB_PORT=8080

# Automatic Heartbeat Interval in Milliseconds (default: 0, disabled)
# If set to a value > 0, heartbeats will be automatically sent to the server
# at the specified interval. This keeps the connection alive.
# Example: 5000 = send a heartbeat every 5 seconds
# Set to 0 to disable automatic heartbeats
HEARTBEAT_INTERVAL_MS=0
