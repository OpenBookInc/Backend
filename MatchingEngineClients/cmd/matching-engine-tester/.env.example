# ====================
# REQUIRED VARIABLES
# ====================

# Matching Server Host (REQUIRED)
# Can be a URL, an IP address, or localhost
# Examples: localhost, 192.168.1.100, matching-server.example.com
SERVER_HOST=localhost

# Matching Server Port (REQUIRED)
# The gRPC port of the matching server
SERVER_PORT=50051

# ====================
# OPTIONAL VARIABLES
# ====================

# Web Interface Port (default: 8080)
# The port on which the web UI will be served
# Access the UI at http://localhost:<WEB_PORT>
WEB_PORT=8080
