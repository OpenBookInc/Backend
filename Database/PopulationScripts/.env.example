# ====================
# REQUIRED VARIABLES
# ====================

# Sportradar API Key (REQUIRED)
# Get your API key from https://developer.sportradar.com
SPORTRADAR_API_KEY=your_api_key_here

# ====================
# OPTIONAL VARIABLES
# ====================

# Rate limit delay between API requests in milliseconds (default: 1000)
# Increase this if you hit rate limits (e.g., 2000 for 2 seconds)
RATE_LIMIT_DELAY_MS=1000

# ====================
# SEASON CONFIGURATION
# ====================

# NFL Season Year (default: current year, e.g., 2024)
# Set this to fetch games from a specific season
NFL_SEASON_YEAR=2024

# NFL Season Type (default: REG)
# Options: REG (regular season), PST (post-season/playoffs), PRE (pre-season)
NFL_SEASON_TYPE=REG

# NFL Week for injury data (default: 1)
# Set to the current week number to get latest player statuses
NFL_WEEK=1

# NBA Season Year (default: current year, e.g., 2024)
# Set this to fetch games from a specific season
NBA_SEASON_YEAR=2024

# NBA Season Type (default: REG)
# Options: REG (regular season), PST (post-season/playoffs)
NBA_SEASON_TYPE=REG

# DATABASE
PG_HOST='blah.amazonaws.com'
PG_PORT='12345'
PG_DATABASE='db-name'
PG_USER='postgres'
PG_PASSWORD='abcdefg123'
PG_KEY_PATH='/path/to/file.pem'
