# ====================
# REQUIRED VARIABLES
# ====================

# Sportradar API Key (REQUIRED)
# Get your API key from https://developer.sportradar.com
SPORTRADAR_API_KEY=your_api_key_here

# ====================
# OPTIONAL VARIABLES
# ====================

# Rate limit delay between API requests in milliseconds (default: 1000)
# Increase this if you hit rate limits (e.g., 2000 for 2 seconds)
RATE_LIMIT_DELAY_MS=1000

# DATABASE
PG_HOST='blah.amazonaws.com'
PG_PORT='12345'
PG_DATABASE='db-name'
PG_USER='postgres'
PG_PASSWORD='abcdefg123'
PG_KEY_PATH='/path/to/file.pem'
